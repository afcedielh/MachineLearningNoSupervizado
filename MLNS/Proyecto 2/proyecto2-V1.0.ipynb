    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import joblib\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Crear directorio de modelos si no existe\\n\",\n",
    "    \"os.makedirs('./models', exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Guardar el pipeline unificado\\n\",\n",
    "    \"model_path = './models/pipeline_ods.pkl'\\n\",\n",
    "    \"joblib.dump(lr_model, model_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"[SUCCESS] Modelo serializado correctamente en: {model_path}\\\")\"\n",
