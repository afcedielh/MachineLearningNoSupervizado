    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-08T23:10:40.223771200Z\",\n",
    "     \"start_time\": \"2026-03-08T23:10:39.772195Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Generación de las gráficas de distribución de clases, longitudes de texto y\\n\",\n",
    "    \"# estadística descriptiva\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Cálculo de longitud\\n\",\n",
    "    \"raw_df['word_count'] = raw_df['text'].apply(lambda x: len(str(x).split()))\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, axes = plt.subplots(1, 2, figsize=(18, 6))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Distribución de la variable objetivo\\n\",\n",
    "    \"sdg_counts = raw_df['sdg'].value_counts()\\n\",\n",
    "    \"sns.barplot(x=sdg_counts.values, y=sdg_counts.index, palette='viridis', ax=axes[0])\\n\",\n",
    "    \"axes[0].set_title('Distribución de Textos por ODS')\\n\",\n",
    "    \"axes[0].set_xlabel('Soporte (Frecuencia)')\\n\",\n",
    "    \"axes[0].set_ylabel('Etiqueta ODS')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Distribución de dispersión de longitud\\n\",\n",
    "    \"sns.histplot(raw_df['word_count'], bins=30, kde=True, color='teal', ax=axes[1])\\n\",\n",
    "    \"axes[1].set_title('Distribución de Longitud de los Textos')\\n\",\n",
    "    \"axes[1].set_xlabel('Número de Palabras')\\n\",\n",
    "    \"axes[1].set_ylabel('Frecuencia')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"display(raw_df['word_count'].describe().to_frame().T)\"\n",
    "   ],\n",
