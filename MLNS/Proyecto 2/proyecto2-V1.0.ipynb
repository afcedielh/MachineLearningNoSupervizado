    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-08T21:14:17.743491Z\",\n",
    "     \"start_time\": \"2026-03-08T21:14:17.578003Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import streamlit as st\\n\",\n",
    "    \"import joblib\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from typing import List, Optional\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Scikit-learn Base Classes (Necesarias para deserializar)\\n\",\n",
    "    \"from sklearn.base import BaseEstimator, TransformerMixin\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 1. Definición del Transformador (Debe ser idéntico al del Notebook)\\n\",\n",
    "    \"class TextPreprocessor(BaseEstimator, TransformerMixin):\\n\",\n",
    "    \"    \\\"\\\"\\\"Limpieza de texto compatible con serialización.\\\"\\\"\\\"\\n\",\n",
    "    \"    def __init__(self, language: str = 'spanish'):\\n\",\n",
    "    \"        self.language = language\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def fit(self, X: pd.Series, y: Optional[pd.Series] = None) -> 'TextPreprocessor':\\n\",\n",
    "    \"        return self\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def transform(self, X: pd.Series) -> List[str]:\\n\",\n",
    "    \"        import nltk\\n\",\n",
    "    \"        from nltk.corpus import stopwords\\n\",\n",
    "    \"        from nltk.stem import SnowballStemmer\\n\",\n",
    "    \"        import re\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Descarga silenciosa en tiempo de ejecución para Streamlit\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            nltk.data.find('corpora/stopwords')\\n\",\n",
    "    \"        except LookupError:\\n\",\n",
    "    \"            nltk.download('stopwords', quiet=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        stop_words = set(stopwords.words(self.language))\\n\",\n",
    "    \"        stemmer = SnowballStemmer(self.language)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        cleaned_texts = []\\n\",\n",
    "    \"        for text in X:\\n\",\n",
    "    \"            text = str(text).lower()\\n\",\n",
    "    \"            text = re.sub(r'[^a-záéíóúñü]', ' ', text)\\n\",\n",
    "    \"            words = [stemmer.stem(w) for w in text.split() if w not in stop_words and len(w) > 2]\\n\",\n",
    "    \"            cleaned_texts.append(' '.join(words))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return cleaned_texts\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 2. Carga del Modelo en Caché\\n\",\n",
    "    \"@st.cache_resource\\n\",\n",
    "    \"def load_model():\\n\",\n",
    "    \"    \\\"\\\"\\\"Carga el pipeline serializado en caché para evitar recargas en cada interacción.\\\"\\\"\\\"\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        return joblib.load('./models/pipeline_ods.pkl')\\n\",\n",
    "    \"    except FileNotFoundError:\\n\",\n",
    "    \"        st.error(\\\"Error: No se encontró el archivo './models/pipeline_ods.pkl'. Ejecuta el notebook primero.\\\")\\n\",\n",
    "    \"        return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 3. Interfaz de Usuario (UI)\\n\",\n",
    "    \"st.set_page_config(page_title=\\\"Clasificador ODS - UNFPA\\\", page_icon=\\\"🌍\\\", layout=\\\"centered\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"st.title(\\\"🌍 Clasificador de Textos: ODS\\\")\\n\",\n",
    "    \"st.markdown(\\\"\\\"\\\"\\n\",\n",
    "    \"Esta aplicación utiliza un pipeline de **Machine Learning (TF-IDF + SVD + Logistic Regression)** para analizar textos de participación ciudadana y relacionarlos con uno de los\\n\",\n",
    "    \"17 Objetivos de Desarrollo Sostenible (ODS) de la ONU.\\n\",\n",
    "    \"\\\"\\\"\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"st.divider()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Input del usuario\\n\",\n",
    "    \"texto_usuario = st.text_area(\\\"Ingresa el texto a clasificar:\\\", height=150,\\n\",\n",
    "    \"                             placeholder=\\\"Ejemplo: El gobierno debe invertir en educación pública...\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Botón de inferencia\\n\",\n",
    "    \"if st.button(\\\"Clasificar Texto\\\", type=\\\"primary\\\"):\\n\",\n",
    "    \"    if len(texto_usuario.strip()) < 10:\\n\",\n",
    "    \"        st.warning(\\\"⚠️ Por favor, ingresa un texto más descriptivo (mínimo 10 caracteres).\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        modelo = load_model()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if modelo is not None:\\n\",\n",
    "    \"            with st.spinner('Procesando lenguaje natural e infiriendo...'):\\n\",\n",
    "    \"                # Inferencia\\n\",\n",
    "    \"                probabilidades = modelo.predict_proba([texto_usuario])[0]\\n\",\n",
    "    \"                indice_max = np.argmax(probabilidades)\\n\",\n",
    "    \"                prob_max = probabilidades[indice_max]\\n\",\n",
    "    \"                ods_predicho = str(modelo.classes_[indice_max]).upper()\\n\",\n",
    "    \"\\n\",\n",
    "    \"                # Evaluación de confianza (Umbral de 40%)\\n\",\n",
    "    \"                st.subheader(\\\"Resultado de la Evaluación\\\")\\n\",\n",
    "    \"                if prob_max < 0.40:\\n\",\n",
    "    \"                    st.error(\\\"❌ **Fuera de Dominio / Alta Incertidumbre**\\\")\\n\",\n",
    "    \"                    st.write(f\\\"El texto no parece relacionarse claramente con un ODS específico.\\\")\\n\",\n",
    "    \"                    st.caption(f\\\"Aproximación más cercana: ODS {ods_predicho} ({prob_max:.1%} de confianza).\\\")\\n\",\n",
    "    \"                else:\\n\",\n",
    "    \"                    st.success(f\\\"✅ **Clasificación Asignada: ODS {ods_predicho}**\\\")\\n\",\n",
    "    \"                    st.progress(float(prob_max), text=f\\\"Nivel de Confianza: {prob_max:.1%}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    # Mostrar el top 3 de predicciones\\n\",\n",
    "    \"                    st.markdown(\\\"### Otras probabilidades cercanas:\\\")\\n\",\n",
    "    \"                    top_3_idx = np.argsort(probabilidades)[-3:][::-1]\\n\",\n",
    "    \"                    for idx in top_3_idx:\\n\",\n",
    "    \"                        if idx != indice_max:\\n\",\n",
    "    \"                            st.write(f\\\"- **ODS {str(modelo.classes_[idx]).upper()}**: {probabilidades[idx]:.1%}\\\")\"\n",
    "   ],\n",
