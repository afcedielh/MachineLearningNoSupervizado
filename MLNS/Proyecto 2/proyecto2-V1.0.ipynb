    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Clasifica un texto evaluando la certidumbre estadística del modelo y decide si el\\n\",\n",
    "    \"# texto pertenece claramente a un ODS\\n\",\n",
    "    \"\\n\",\n",
    "    \"def clasificar_texto_ods(texto_crudo: str, modelo_entrenado: Pipeline, umbral_confianza: float = 0.40) -> str:\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Validación del texto\\n\",\n",
    "    \"    if not isinstance(texto_crudo, str) or len(texto_crudo.strip()) < 5:\\n\",\n",
    "    \"        raise ValueError(\\\"El texto de entrada debe ser un string válido de al menos 5 caracteres.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if not hasattr(modelo_entrenado, 'predict_proba'):\\n\",\n",
    "    \"        raise TypeError(\\\"El clasificador no soporta inferencia probabilística (predict_proba).\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    texto_arr = [texto_crudo]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Ejecuta el pipeline completo\\n\",\n",
    "    \"    probabilidades_arr = modelo_entrenado.predict_proba(texto_arr)[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 3. Análisis de Dimensionalidad y Extracción\\n\",\n",
    "    \"    # Para identificar la clase más probable y su nivel de confianza\\n\",\n",
    "    \"    indice_max_prob = np.argmax(probabilidades_arr)\\n\",\n",
    "    \"    probabilidad_maxima = probabilidades_arr[indice_max_prob]\\n\",\n",
    "    \"    clase_predicha = modelo_entrenado.classes_[indice_max_prob]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Forzar conversión a string por si las etiquetas son int64\\n\",\n",
    "    \"    clase_str = str(clase_predicha)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 4. Decide si la clasificación es confiable o no\\n\",\n",
    "    \"    if probabilidad_maxima < umbral_confianza:\\n\",\n",
    "    \"        return (f\\\"   NO PERTENECE A UN ODS CLARO.\\\\n\\\"\\n\",\n",
    "    \"                f\\\"   El modelo presenta demasiada incertidumbre.\\\\n\\\"\\n\",\n",
    "    \"                f\\\"   (Aproximación más cercana: {clase_str} con {probabilidad_maxima:.1%} de confianza).\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return (f\\\"   PERTENECE A UN ODS.\\\\n\\\"\\n\",\n",
    "    \"            f\\\"   Clasificación asignada: ODS {clase_str.upper()}\\\\n\\\"\\n\",\n",
    "    \"            f\\\"   (Confianza estadística: {probabilidad_maxima:.1%})\\\")\"\n",
    "   ],\n",
