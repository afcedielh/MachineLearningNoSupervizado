    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"# Clasificación Supervisada de Textos para Objetivos de Desarrollo Sostenible (ODS)\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Objetivo Principal:** Desarrollar una solución, basada en técnicas de procesamiento de lenguaje natural y machine learning, que facilite la interpretación y análisis de información textual para la identificación de relaciones semánticas con los Objetivos de Desarrollo Sostenibles.\"\n",
    "   ],\n",
    "   \"id\": \"fd519e73a7701909\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-08T23:10:39.116831200Z\",\n",
    "     \"start_time\": \"2026-03-08T23:10:39.093766500Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"import re\\n\",\n",
    "    \"import warnings\\n\",\n",
    "    \"from typing import List, Optional\\n\",\n",
    "    \"\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Scikit-learn\\n\",\n",
    "    \"from sklearn.model_selection import train_test_split, StratifiedKFold, RandomizedSearchCV\\n\",\n",
    "    \"from sklearn.pipeline import Pipeline\\n\",\n",
    "    \"from sklearn.feature_extraction.text import TfidfVectorizer\\n\",\n",
    "    \"from sklearn.decomposition import TruncatedSVD\\n\",\n",
    "    \"from sklearn.linear_model import LogisticRegression\\n\",\n",
    "    \"from sklearn.metrics import classification_report, confusion_matrix\\n\",\n",
    "    \"from sklearn.base import BaseEstimator, TransformerMixin\\n\",\n",
    "    \"\\n\",\n",
    "    \"# NLP\\n\",\n",
    "    \"import nltk\\n\",\n",
    "    \"from nltk.corpus import stopwords\\n\",\n",
    "    \"from nltk.stem import SnowballStemmer\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Eliminamos las stopwords (palabras poco relevantes)\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    nltk.data.find('corpora/stopwords')\\n\",\n",
    "    \"except LookupError:\\n\",\n",
    "    \"    nltk.download('stopwords', quiet=True)\"\n",
    "   ],\n",
    "   \"id\": \"74035da6fab81df6\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 35\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-08T23:10:39.148436500Z\",\n",
    "     \"start_time\": \"2026-03-08T23:10:39.126849300Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"SEED = 42\\n\",\n",
    "    \"np.random.seed(SEED)\\n\",\n",
    "    \"warnings.filterwarnings('ignore')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.style.use('seaborn-v0_8-whitegrid')\\n\",\n",
    "    \"sns.set_context(\\\"notebook\\\", font_scale=1.1)\\n\",\n",
    "    \"plt.rcParams['figure.figsize'] = (10, 6)\"\n",
    "   ],\n",
    "   \"id\": \"ce131ba0302bcea7\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 36\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"1. Preparación de los textos utilizando el esquema de bolsa de palabras (BOW)l con una pesado TF-IDF. Para este paso construir un pipeline que integre las transformaciones que se consideren adecuadas.\",\n",
    "   \"id\": \"af576dcc308209b5\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-08T23:10:39.723732700Z\",\n",
    "     \"start_time\": \"2026-03-08T23:10:39.151942600Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"#  Carga el archivo de Excel y realiza las validaciones para\\n\",\n",
    "    \"#  garantizar la integridad estructural del dataset antes del procesamiento.\\n\",\n",
    "    \"def load_and_validate_data(filepath: str, column_mapping: dict = None) -> pd.DataFrame:\\n\",\n",
    "    \"    # Carga el dataset Excel y realiza validación defensiva de estructura y columnas\\n\",\n",
    "    \"    if not os.path.exists(filepath):\\n\",\n",
    "    \"        raise FileNotFoundError(f\\\"[ERROR] Archivo no encontrado en la ruta: {filepath}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Carga de datos\\n\",\n",
    "    \"    raw_df = pd.read_excel(filepath)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Validación Defensiva de Columnas\\n\",\n",
    "    \"    print(f\\\"[INFO] Dataset cargado. Dimensiones exactas (Filas, Columnas): {raw_df.shape}\\\")\\n\",\n",
    "    \"    print(f\\\"[INFO] Columnas originales encontradas en el archivo: {raw_df.columns.tolist()}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Renombramiento dinámico para estandarizar el DataFrame\\n\",\n",
    "    \"    if column_mapping:\\n\",\n",
    "    \"        raw_df = raw_df.rename(columns=column_mapping)\\n\",\n",
    "    \"        print(f\\\"[INFO] Columnas tras el mapeo: {raw_df.columns.tolist()}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Validación para prevenir KeyError\\n\",\n",
    "    \"    required_cols = ['text', 'sdg']\\n\",\n",
    "    \"    missing_cols = [col for col in required_cols if col not in raw_df.columns]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if missing_cols:\\n\",\n",
    "    \"        raise KeyError(f\\\"[ERROR CRÍTICO] Faltan las columnas {missing_cols}. \\\"\\n\",\n",
    "    \"                       f\\\"Por favor, ajusta el diccionario 'MAPEO_COLUMNAS' con los nombres reales de tu Excel.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 2. Validación de Tipos y Nulos\\n\",\n",
    "    \"    print(\\\"\\\\n--- Validación de Valores Nulos ---\\\")\\n\",\n",
    "    \"    print(raw_df.isnull().sum())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Eliminación de posibles nulos\\n\",\n",
    "    \"    if raw_df['text'].isnull().any() or raw_df['sdg'].isnull().any():\\n\",\n",
    "    \"        print(\\\"[WARN] Se detectaron valores nulos. Procediendo a eliminación (dropna).\\\")\\n\",\n",
    "    \"        raw_df = raw_df.dropna(subset=['text', 'sdg']).reset_index(drop=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return raw_df\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Ruta actualizada al archivo Excel\\n\",\n",
    "    \"DATA_PATH = \\\"./data/dataset.xlsx\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"MAPEO_COLUMNAS = {\\n\",\n",
    "    \"    'textos': 'text',\\n\",\n",
    "    \"    'ODS': 'sdg'\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Ejecución\\n\",\n",
    "    \"raw_df = load_and_validate_data(DATA_PATH, column_mapping=MAPEO_COLUMNAS)\"\n",
    "   ],\n",
    "   \"id\": \"a4c943f5faf8a48c\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"[INFO] Dataset cargado. Dimensiones exactas (Filas, Columnas): (9656, 2)\\n\",\n",
    "      \"[INFO] Columnas originales encontradas en el archivo: ['textos', 'ODS']\\n\",\n",
    "      \"[INFO] Columnas tras el mapeo: ['text', 'sdg']\\n\",\n",
    "      \"\\n\",\n",
    "      \"--- Validación de Valores Nulos ---\\n\",\n",
    "      \"text    0\\n\",\n",
    "      \"sdg     0\\n\",\n",
    "      \"dtype: int64\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
