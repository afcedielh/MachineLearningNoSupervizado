    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-08T23:10:40.289156400Z\",\n",
    "     \"start_time\": \"2026-03-08T23:10:40.269053500Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Preprocesamiento de textos para limpieza y normalización e integrarse al pipeline.\\n\",\n",
    "    \"class TextPreprocessor(BaseEstimator, TransformerMixin):\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Inicialización de preprocesador con el idioma Español\\n\",\n",
    "    \"    def __init__(self, language: str = 'spanish'):\\n\",\n",
    "    \"        self.language = language\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def fit(self, X: pd.Series, y: Optional[pd.Series] = None) -> 'TextPreprocessor':\\n\",\n",
    "    \"        return self\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def transform(self, X: pd.Series) -> List[str]:\\n\",\n",
    "    \"        # Inicialización (soluciona error BrokenProcessPool)\\n\",\n",
    "    \"        import nltk\\n\",\n",
    "    \"        from nltk.corpus import stopwords\\n\",\n",
    "    \"        from nltk.stem import SnowballStemmer\\n\",\n",
    "    \"        import re\\n\",\n",
    "    \"\\n\",\n",
    "    \"        stop_words = set(stopwords.words(self.language))\\n\",\n",
    "    \"        stemmer = SnowballStemmer(self.language)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        cleaned_texts = []\\n\",\n",
    "    \"        for text in X:\\n\",\n",
    "    \"            text = str(text).lower()\\n\",\n",
    "    \"            text = re.sub(r'[^a-záéíóúñü]', ' ', text)\\n\",\n",
    "    \"            words = [stemmer.stem(w) for w in text.split() if w not in stop_words and len(w) > 2]\\n\",\n",
    "    \"            cleaned_texts.append(' '.join(words))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return cleaned_texts\"\n",
    "   ],\n",
    "   \"id\": \"183d1e2c4f737af5\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 39\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"2. Desarrollo de un modelo de clasificación que permita relacionar un texto con un ODS. Para manejar la complejidad del espacio de entrada aplicar un algoritmo de reducción de la dimensionalidad.\",\n",
    "   \"id\": \"1ddd90b7c329573a\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-08T23:11:00.221978Z\",\n",
    "     \"start_time\": \"2026-03-08T23:10:40.292166900Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"X = raw_df['text']\\n\",\n",
    "    \"y = raw_df['sdg']\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Separación de variables independientes de la variable objetivo\\n\",\n",
    "    \"X_train, X_test, y_train, y_test = train_test_split(\\n\",\n",
    "    \"    X, y,\\n\",\n",
    "    \"    test_size=0.2,\\n\",\n",
    "    \"    random_state=SEED,\\n\",\n",
    "    \"    stratify=y\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Creación de pipeline para ingeniería de características\\n\",\n",
    "    \"feature_engineering_pipeline = Pipeline([\\n\",\n",
    "    \"    ('cleaner', TextPreprocessor()), # Limpiar textos\\n\",\n",
    "    \"    ('tfidf', TfidfVectorizer(max_features=5000, min_df=3, max_df=0.85)), # TD-IDF\\n\",\n",
    "    \"    ('svd', TruncatedSVD(n_components=300, random_state=SEED)) # Reducción de dimensionalidad\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Pipeline unificado para la Regresión Logística\\n\",\n",
    "    \"model_pipeline = Pipeline([\\n\",\n",
    "    \"    ('features', feature_engineering_pipeline),\\n\",\n",
    "    \"    ('classifier', LogisticRegression(solver='lbfgs', max_iter=1000, random_state=SEED))\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Espacio de búsqueda de hiperparámetros\\n\",\n",
    "    \"param_distributions = {\\n\",\n",
    "    \"    'features__svd__n_components': [100, 200, 300],\\n\",\n",
    "    \"    'classifier__C': [0.1, 1.0, 10.0],\\n\",\n",
    "    \"    'classifier__class_weight': ['balanced', None]\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Validación cruzada para encontrar la mejor combinación de hiperparámetros\\n\",\n",
    "    \"# Se usa RandomizedSearchCV para exploración más rápida\\n\",\n",
    "    \"search_cv = RandomizedSearchCV(\\n\",\n",
    "    \"    estimator=model_pipeline,\\n\",\n",
    "    \"    param_distributions=param_distributions,\\n\",\n",
    "    \"    n_iter=5,\\n\",\n",
    "    \"    scoring='f1_macro',\\n\",\n",
    "    \"    cv=StratifiedKFold(n_splits=3, shuffle=True, random_state=SEED),\\n\",\n",
    "    \"    n_jobs=-1,\\n\",\n",
    "    \"    random_state=SEED,\\n\",\n",
    "    \"    verbose=1\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Iniciando entrenamiento cruzado...\\\")\\n\",\n",
    "    \"search_cv.fit(X_train, y_train)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Modelo entrenado. Mejores hiperparámetros:\\\\n{search_cv.best_params_}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Asignación del mejor modelo encontrado\\n\",\n",
    "    \"lr_model = search_cv.best_estimator_\"\n",
    "   ],\n",
    "   \"id\": \"3fe2b486f8260a37\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Iniciando entrenamiento cruzado...\\n\",\n",
    "      \"Fitting 3 folds for each of 5 candidates, totalling 15 fits\\n\",\n",
    "      \"Modelo entrenado. Mejores hiperparámetros:\\n\",\n",
    "      \"{'features__svd__n_components': 300, 'classifier__class_weight': 'balanced', 'classifier__C': 1.0}\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 40\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"3. Evaluación del modelo con textos que no hayan sido utilizados para el aprendizaje.\",\n",
    "   \"id\": \"6d75442f6501203\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-08T23:11:01.484984100Z\",\n",
    "     \"start_time\": \"2026-03-08T23:11:00.255016700Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Predicción del modelo\\n\",\n",
    "    \"y_pred = lr_model.predict(X_test)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Reporte de clasificación\\n\",\n",
    "    \"print(\\\"=\\\"*60)\\n\",\n",
    "    \"print(\\\"REPORTE DE CLASIFICACIÓN\\\")\\n\",\n",
    "    \"print(\\\"=\\\"*60)\\n\",\n",
    "    \"print(classification_report(y_test, y_pred))\\n\",\n",
    "    \"\\n\",\n",
